generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String        @id @default(uuid())
  name              String
  avatarUrl         String?
  role              String        // "client" | "professional" | "guest"
  location          String
  isVerified        Boolean       @default(false)
  verificationLevel String        @default("none") // "premium" | "standard" | "none"
  professional      Professional?
}

model Professional {
  id               String              @id @default(uuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id])
  title            String
  specialty        String
  rating           Float               @default(0)
  reviewCount      Int                 @default(0)
  hourlyRate       Int
  yearsExperience  Int                 @default(0)
  completedJobs    Int                 @default(0)
  recurringClients Int                 @default(0)
  responseTime     String              @default("1h")
  
  badges           VerificationBadge[]
  education        Education[]
  experience       WorkExperience[]
  portfolio        PortfolioItem[]
}

model VerificationBadge {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  type           String       // "biometric" | "conocer" | "sat"
  label          String
  sublabel       String
  status         String       // "verified" | "pending" | "unverified"
  icon           String
}

model Education {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  institution    String
  degree         String
  year           String
}

model WorkExperience {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  company        String
  position       String
  period         String
}

model PortfolioItem {
  id             String       @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  title          String
  imageUrl       String
  span           String?      // "large" | "normal" | "wide"
}
